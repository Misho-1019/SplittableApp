{
  "expo": {
    "name": "Splittable",
    "slug": "splittable",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "splittable",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "newArchEnabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.splittable.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FF6B6B"
      },
      "package": "com.splittable.app",
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "build": {
        "assets": [
          "./assets/fonts"
        ]
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Splittable to access your photos to attach receipts.",
          "cameraPermission": "Allow Splittable to use your camera to capture receipts."
        }
      ],
      "expo-font"
    ]
  }
}
